{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designlab.local/schemas/pipeline.output.json",
  "title": "Pipeline output",
  "description": "Aggregated pipeline response with partial results and explicit failure step metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": ["compose", "pipeline"],
  "properties": {
    "schemaRef": {
      "type": "string",
      "description": "Schema reference returned by compose, reusable across tools."
    },
    "schemaRefCreatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the schemaRef was created."
    },
    "schemaRefExpiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the schemaRef expires. Use schema.save to persist before expiry."
    },
    "schemaRefTtlWarning": {
      "type": "object",
      "additionalProperties": false,
      "description": "Proactive warning when schemaRef TTL is approaching expiration (< 5 minutes remaining).",
      "required": ["message", "remainingMs", "recommendation"],
      "properties": {
        "message": {
          "type": "string",
          "description": "Human-readable warning message."
        },
        "remainingMs": {
          "type": "number",
          "description": "Milliseconds remaining until schemaRef expires."
        },
        "recommendation": {
          "type": "string",
          "description": "Actionable recommendation for the agent."
        }
      }
    },
    "compose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "componentCount"],
      "properties": {
        "object": { "type": "string" },
        "context": { "type": "string" },
        "layout": { "type": "string" },
        "componentCount": { "type": "number", "minimum": 0 }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "errors", "warnings"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "invalid", "skipped"]
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue" }
        }
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meta"],
      "properties": {
        "html": {
          "type": "string",
          "description": "Rendered HTML when renderApply=true."
        },
        "tokenCssRef": {
          "type": "string",
          "description": "Reference to token CSS artifact when compact mode is enabled."
        },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "description": "Render metadata summary."
        }
      }
    },
    "code": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "styling", "output"],
      "properties": {
        "framework": {
          "type": "string",
          "enum": ["react", "vue", "html"]
        },
        "styling": {
          "type": "string",
          "enum": ["inline", "tokens", "tailwind"]
        },
        "output": {
          "type": "string"
        }
      }
    },
    "saved": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "One-line natural language description of what was generated."
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalNodes": { "type": "integer", "minimum": 0 },
        "componentsUsed": { "type": "integer", "minimum": 0 },
        "fieldsBound": { "type": "integer", "minimum": 0 },
        "responseBytes": { "type": "integer", "minimum": 0 },
        "fieldsOmitted": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "reason"],
            "properties": {
              "field": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      },
      "description": "Quality metrics for the pipeline output."
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps", "duration"],
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["compose", "validate", "render", "codegen", "save"]
          }
        },
        "stepLatency": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          },
          "description": "Per-step latency in milliseconds."
        },
        "duration": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "code", "message"],
      "properties": {
        "step": {
          "type": "string",
          "enum": ["compose", "validate", "render", "codegen", "save"]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "path": { "type": "string" },
        "hint": { "type": "string" },
        "severity": { "type": "string" },
        "nodeId": { "type": "string" },
        "component": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
