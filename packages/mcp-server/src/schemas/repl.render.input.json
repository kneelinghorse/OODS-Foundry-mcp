{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designlab.local/schemas/repl.render.input.json",
  "title": "Agentic REPL render input",
  "type": "object",
  "properties": {
    "dslVersion": {
      "type": "string",
      "description": "DSL version to use for this request. Defaults to the current version (1.0)."
    },
    "mode": {
      "type": "string",
      "enum": [
        "full",
        "patch"
      ],
      "default": "full"
    },
    "schema": {
      "$ref": "./repl.ui.schema.json"
    },
    "schemaRef": {
      "type": "string",
      "description": "Reference to a cached UiSchema returned by design.compose."
    },
    "patch": {
      "$ref": "./repl.patch.json"
    },
    "baseTree": {
      "$ref": "./repl.ui.schema.json"
    },
    "researchContext": {
      "type": "object",
      "description": "Optional research bundle from Stage1 discovery to influence rendering.",
      "additionalProperties": true
    },
    "options": {
      "type": "object",
      "properties": {
        "includeTree": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "output": {
      "type": "object",
      "description": "Optional render output controls. Omitting this object preserves full-document behavior.",
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "document",
            "fragments"
          ],
          "default": "document"
        },
        "strict": {
          "type": "boolean",
          "default": false
        },
        "includeCss": {
          "type": "boolean",
          "default": true
        },
        "compact": {
          "type": "boolean",
          "description": "When true, omit the full token CSS from the response and return a tokenCssRef instead. Reduces response size by ~40%. Default false for repl.render, true for pipeline.",
          "default": false
        },
        "depth": {
          "type": "number",
          "description": "Reserved for v2 fragment-depth controls; currently ignored."
        }
      },
      "additionalProperties": false
    },
    "apply": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "full" } },
        "required": ["mode"]
      },
      "then": {
        "anyOf": [
          { "required": ["schema"] },
          { "required": ["schemaRef"] }
        ]
      }
    },
    {
      "if": { "not": { "required": ["mode"] } },
      "then": {
        "anyOf": [
          { "required": ["schema"] },
          { "required": ["schemaRef"] }
        ]
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "patch" } },
        "required": ["mode"]
      },
      "then": {
        "required": [
          "patch",
          "baseTree"
        ]
      }
    }
  ],
  "additionalProperties": false
}
