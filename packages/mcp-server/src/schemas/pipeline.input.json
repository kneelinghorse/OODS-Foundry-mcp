{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designlab.local/schemas/pipeline.input.json",
  "title": "Pipeline input",
  "description": "Execute the full design pipeline (compose -> validate -> render -> codegen) in a single call.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "dslVersion": {
      "type": "string",
      "description": "DSL version to use for this request. Defaults to the current version (1.0)."
    },
    "object": {
      "type": "string",
      "minLength": 1,
      "description": "Object name from the OODS registry (e.g., Subscription, User)."
    },
    "intent": {
      "type": "string",
      "minLength": 1,
      "description": "Natural-language description of the desired UI."
    },
    "context": {
      "type": "string",
      "enum": ["detail", "list", "form", "timeline", "card", "inline"],
      "description": "View context for object-aware composition."
    },
    "layout": {
      "type": "string",
      "enum": ["dashboard", "form", "detail", "list", "card", "timeline", "auto"],
      "description": "Layout template to use."
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme": {
          "type": "string",
          "description": "Theme token (e.g., 'light', 'dark')."
        },
        "metricColumns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "Number of metric columns for dashboard layout."
        },
        "fieldGroups": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Number of field groups for form layout."
        },
        "tabCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Number of tabs for detail layout."
        },
        "tabLabels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Custom tab labels for detail layout."
        },
        "componentOverrides": {
          "type": "object",
          "description": "Slot-name to component-name overrides (e.g., { 'items': 'Table' }).",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "actionMappings": {
      "type": "array",
      "description": "Sprint 88: Stage1 BridgeSummary action_mappings, flat verb-keyed entries. See docs/integration/stage1-oods-contract.md §2c.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["verb"],
        "properties": {
          "verb": { "type": "string", "minLength": 1 },
          "oodsTrait": { "type": "string" },
          "trait": { "type": "string" },
          "object": { "type": "string" },
          "component": { "type": "string" },
          "slot": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "framework": {
      "type": "string",
      "enum": ["react", "vue", "html"],
      "description": "Target framework for code generation."
    },
    "styling": {
      "type": "string",
      "enum": ["inline", "tokens", "tailwind"],
      "description": "Styling strategy for code generation."
    },
    "save": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "description": "Schema name to persist (shorthand)."
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Schema name to persist."
            },
            "tags": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tags to attach to the saved schema."
            }
          }
        }
      ],
      "description": "Optional schema save config. String for name-only, or { name, tags } for full control."
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skipValidation": {
          "type": "boolean",
          "description": "Skip the validate step (default false)."
        },
        "skipRender": {
          "type": "boolean",
          "description": "Skip the render step (default false)."
        },
        "checkA11y": {
          "type": "boolean",
          "description": "Enable a11y contrast checks in validate (default false)."
        },
        "renderApply": {
          "type": "boolean",
          "description": "Render with apply=true to include HTML output (default true)."
        },
        "compact": {
          "type": "boolean",
          "description": "When true (default), omit token CSS from render output and return tokenCssRef instead. Reduces response size by ~40%."
        },
        "typescript": {
          "type": "boolean",
          "description": "Alias: enable TypeScript output in code generation."
        },
        "styling": {
          "type": "string",
          "enum": ["inline", "tokens", "tailwind"],
          "description": "Alias: styling strategy. Overridden by top-level styling if both provided."
        },
        "framework": {
          "type": "string",
          "enum": ["react", "vue", "html"],
          "description": "Alias: target framework. Overridden by top-level framework if both provided."
        }
      }
    }
  }
}
