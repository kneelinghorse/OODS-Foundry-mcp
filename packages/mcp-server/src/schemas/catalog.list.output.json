{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["components", "totalCount", "returnedCount", "page", "pageSize", "hasMore", "detail", "generatedAt", "stats"],
  "properties": {
    "components": {
      "type": "array",
      "description": "Array of component catalog entries",
      "items": {
        "type": "object",
        "required": ["name", "displayName", "categories", "tags", "contexts", "regions", "traits"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Component name (e.g., 'Button', 'Card')"
          },
          "displayName": {
            "type": "string",
            "description": "Human-readable display name"
          },
          "categories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Component categories (e.g., ['core'], ['data'])"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Component tags for search and discovery"
          },
          "contexts": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Rendering contexts where component can be used"
          },
          "regions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "UI regions where component can appear"
          },
          "traits": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of trait capabilities (e.g., ['Editable', 'Searchable'])"
          },
          "propSchema": {
            "type": "object",
            "description": "Component prop schema with types and defaults (detail=full only).",
            "additionalProperties": true
          },
          "slots": {
            "type": "object",
            "description": "Slot definitions with accepted types and roles (detail=full only).",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "accept": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "role": {
                  "type": "string"
                }
              }
            }
          },
          "codeReferences": {
            "type": "array",
            "description": "References into Storybook `.stories.tsx` files (usage patterns + minimal snippets, detail=full only).",
            "items": {
              "type": "object",
              "required": ["kind", "path", "snippet"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["storybook", "code-connect"],
                  "description": "Reference kind."
                },
                "path": {
                  "type": "string",
                  "description": "Repo-relative POSIX path to a source file containing a usage example."
                },
                "title": {
                  "type": "string",
                  "description": "Storybook title when available."
                },
                "snippet": {
                  "type": "string",
                  "description": "Concise usage snippet extracted from the story file."
                }
              },
              "additionalProperties": false
            }
          },
          "codeSnippet": {
            "type": "string",
            "description": "Convenience: best single snippet picked from codeReferences (detail=full only)."
          }
        },
        "additionalProperties": false
      }
    },
    "totalCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of components that match the filters (before pagination)."
    },
    "returnedCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of components returned in this page."
    },
    "page": {
      "type": "integer",
      "minimum": 1,
      "description": "1-based page index used for pagination."
    },
    "pageSize": {
      "type": "integer",
      "minimum": 0,
      "description": "Page size used for pagination. 0 when there are no results."
    },
    "hasMore": {
      "type": "boolean",
      "description": "Whether more components are available after this page."
    },
    "detail": {
      "type": "string",
      "enum": ["summary", "full"],
      "description": "Detail level applied to component entries."
    },
    "generatedAt": {
      "type": "string",
      "description": "ISO timestamp when catalog was generated"
    },
    "stats": {
      "type": "object",
      "required": ["componentCount", "traitCount"],
      "properties": {
        "componentCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total components in catalog"
        },
        "traitCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total traits available"
        },
        "filteredCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total components matching the active filters"
        }
      },
      "additionalProperties": false
    },
    "suggestions": {
      "type": "object",
      "description": "Suggested filter values when a query returns zero results.",
      "properties": {
        "traits": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Closest matching trait names."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
