{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designlab.local/schemas/design.compose.output.json",
  "title": "Design compose output",
  "description": "Generated UiSchema with component selections and validation result.",
  "type": "object",
  "required": ["status", "layout", "schema", "selections", "warnings"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "error"],
      "description": "Whether composition succeeded."
    },
    "layout": {
      "type": "string",
      "description": "The layout template that was used."
    },
    "schema": {
      "$ref": "./repl.ui.schema.json",
      "description": "The generated UiSchema (with slot placeholders intact for agent customization)."
    },
    "schemaRef": {
      "type": "string",
      "description": "Server-managed reference to the generated schema for reuse in validate/render/code.generate."
    },
    "schemaRefCreatedAt": {
      "type": "string",
      "description": "ISO timestamp when the schemaRef was created."
    },
    "schemaRefExpiresAt": {
      "type": "string",
      "description": "ISO timestamp when the schemaRef expires."
    },
    "selections": {
      "type": "array",
      "items": { "$ref": "#/$defs/slotSelection" },
      "description": "Component selection results per slot."
    },
    "validation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "invalid", "skipped"]
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue" }
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" },
      "description": "Non-fatal issues during composition."
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" },
      "description": "Fatal issues that prevented composition."
    },
    "objectUsed": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Object name from the registry." },
        "version": { "type": "string", "description": "Object version." },
        "traits": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Trait names composed into this object."
        },
        "fieldsComposed": { "type": "number", "description": "Total fields from merged trait schemas." },
        "viewExtensionsApplied": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Count of view_extensions applied per context."
        }
      },
      "required": ["name", "version", "traits", "fieldsComposed", "viewExtensionsApplied"],
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "properties": {
        "intentParsed": { "type": "string" },
        "layoutDetected": { "type": "string" },
        "slotCount": { "type": "number" },
        "nodeCount": { "type": "number" },
        "objectAutoDetected": { "type": "string", "description": "Object name auto-detected from intent string." },
        "contextAutoDetected": { "type": "string", "description": "Context auto-detected from intent string." },
        "intentSynthetic": { "type": "boolean", "description": "True when intent was synthetically generated from object + context." },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Human-readable warning messages from composition."
        },
        "intelligence": {
          "type": "object",
          "description": "Compositor intelligence indicators (Sprint 73).",
          "properties": {
            "fieldsExpanded": { "type": "boolean", "description": "Whether template slots were dynamically expanded." },
            "slotsExpanded": { "type": "number", "description": "Number of slots added by expansion." },
            "expansionReason": { "type": "string", "description": "Reason for slot expansion." },
            "patternsApplied": { "type": "number", "description": "Number of composite slot patterns applied." },
            "positionAffinityUsed": { "type": "boolean", "description": "Whether position-aware scoring was used." },
            "fieldAffinityUsed": { "type": "boolean", "description": "Whether field-type-aware scoring was used." },
            "intentSectionsParsed": { "type": "integer", "description": "Number of intent sections parsed from multi-section prompts." },
            "sectionContextUsed": { "type": "boolean", "description": "Whether section context influenced slot composition." }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "slotSelection": {
      "type": "object",
      "required": ["slotName", "intent", "candidates"],
      "properties": {
        "slotName": { "type": "string" },
        "intent": { "type": "string" },
        "selectedComponent": { "type": "string" },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "confidence", "reason"],
            "properties": {
              "name": { "type": "string" },
              "confidence": { "type": "number" },
              "reason": { "type": "string" },
              "keywordTagMatches": { "type": "number" },
              "keywordTraitMatches": { "type": "number" },
              "contextTagMatches": { "type": "number" },
              "contextTraitMatches": { "type": "number" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "path": { "type": "string" },
        "hint": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
