{
  "name": "@oods/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Typed TypeScript client for the OODS Foundry MCP server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@oods/mcp-server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
