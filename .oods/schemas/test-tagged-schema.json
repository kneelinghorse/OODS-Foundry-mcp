    "objectSchema": {
      "label": {
        "type": "string",
        "required": true,
        "description": "Human-readable display name rendered in primary surfaces.",
        "semanticType": "text.label"
      },
      "description": {
        "type": "string",
        "required": false,
        "description": "Supporting description used in detail and card contexts.",
        "semanticType": "text.description"
      },
      "placeholder": {
        "type": "string",
        "required": false,
        "description": "Hint copy surfaced in form fields when the label is empty.",
        "semanticType": "text.placeholder"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Canonical lifecycle state derived from the states parameter. This is the single source\nof truth for the entity's current lifecycle position. Consumed by Colorized to resolve\nvisual tokens, and by view extensions to render StatusBadge and StatusTimeline.\n",
        "semanticType": "status.state"
      },
      "state_history": {
        "type": "StateTransition[]",
        "required": false,
        "description": "Chronological log of state transitions. Each entry records the before/after states,\ntimestamp, and (when governance is enabled) the actor, reason, and transition metadata.\nRendered by StatusTimeline in the detail and timeline views.\n\nEntry structure:\n  - from: string (previous state)\n  - to: string (new state)\n  - timestamp: ISO 8601 datetime\n  - actor_id: string (user/system who triggered the transition, optional)\n  - reason: string (human-readable justification, required when requireTransitionReason is true)\n  - transition_metadata: Record<string, unknown> (arbitrary context, optional)\n",
        "semanticType": "timeline.state_transition"
      },
      "allowed_transitions": {
        "type": "string[]",
        "required": false,
        "description": "Materialized list of valid next states from the current status, computed from the\ntransitionRules parameter. When transitionRules is null (open model), this contains\nall states except the current one. Used by StatusSelector to disable invalid options\nand by StatusBadge to indicate available paths.\n",
        "semanticType": "status.navigation"
      },
      "created_at": {
        "type": "datetime",
        "required": true,
        "description": "Timestamp recording when the entity was first created.",
        "semanticType": "audit.created_at"
      },
      "updated_at": {
        "type": "datetime",
        "required": false,
        "description": "Timestamp for the most recent modification, when available.",
        "semanticType": "audit.updated_at"
      },
      "last_event": {
        "type": "string",
        "required": true,
        "description": "Lifecycle event associated with the most recent timestamp mutation.",
        "semanticType": "audit.event.type"
      },
      "last_event_at": {
        "type": "datetime",
        "required": false,
        "description": "Timestamp for the lifecycle event captured in last_event.",
        "semanticType": "audit.event.timestamp"
      },
      "unit_amount_cents": {
        "type": "number",
        "required": true,
        "description": "Base unit price expressed in the smallest currency denomination.",
        "semanticType": "commerce.price.amount"
      },
      "currency": {
        "type": "string",
        "required": true,
        "description": "ISO currency code for the unit amount.",
        "semanticType": "commerce.price.currency"
      },
      "pricing_model": {
        "type": "string",
        "required": true,
        "description": "Monetization model applied to the entity.",
        "semanticType": "commerce.price.model"
      },
      "billing_interval": {
        "type": "string",
        "required": false,
        "description": "Billing cadence when pricing_model indicates recurring revenue.",
        "semanticType": "commerce.price.interval"
      },
      "tax_behavior": {
        "type": "string",
        "required": true,
        "description": "Defines whether taxes are included in the displayed price.",
        "enum": [
          "exclusive",
          "inclusive"
        ],
        "semanticType": "commerce.price.tax_behavior"
      },
      "classification_metadata": {
        "type": "ClassificationMetadata",
        "required": true,
        "description": "Operational metadata describing mode, storage model, governance rules, and audit timestamps.\n",
        "semanticType": "classification.metadata"
      },
      "categories": {
        "type": "CategoryNode[]",
        "required": false,
        "description": "Ordered taxonomy nodes scoped to the object.",
        "semanticType": "classification.categories"
      },
      "primary_category_id": {
        "type": "string",
        "required": false,
        "description": "Identifier of the canonical taxonomy node.",
        "semanticType": "classification.primary"
      },
      "primary_category_path": {
        "type": "string",
        "required": false,
        "description": "Human-readable breadcrumb path (Electronics > Mobile > Android)."
      },
      "tags": {
        "type": "Tag[]",
        "required": false,
        "description": "Canonical tag collection after synonym collapse.",
        "semanticType": "classification.tags"
      },
      "tag_count": {
        "type": "number",
        "required": false,
        "description": "Number of canonical tags assigned to the object."
      },
      "tag_preview": {
        "type": "string",
        "required": false,
        "description": "Denormalized comma-delimited preview for list renders."
      },
      "searchQuery": {
        "type": "string",
        "required": false,
        "description": "The current search query string entered by the user.",
        "semanticType": "input.search.query"
      },
      "searchActive": {
        "type": "boolean",
        "required": false,
        "description": "Whether the search input is currently focused or has a non-empty query.",
        "semanticType": "state.search.active"
      },
      "filters": {
        "type": "object[]",
        "required": false,
        "description": "Array of available filter descriptors. Each entry defines a filterable dimension:\n  - field: string (the schema field to filter on)\n  - label: string (display label)\n  - type: \"select\" | \"multi-select\" | \"range\" | \"boolean\" | \"date-range\"\n  - options: array of { value, label } for select/multi-select types\n",
        "semanticType": "input.filter.descriptors"
      },
      "activeFilters": {
        "type": "object[]",
        "required": false,
        "description": "Array of currently applied filter values:\n  - field: string (matches a filter descriptor field)\n  - operator: \"eq\" | \"in\" | \"range\" | \"gt\" | \"lt\" | \"between\"\n  - value: unknown (the selected filter value or values)\n",
        "semanticType": "state.filter.active"
      },
      "filterCount": {
        "type": "number",
        "required": true,
        "description": "Computed count of currently active filters.",
        "semanticType": "metric.filter.count"
      },
      "page": {
        "type": "number",
        "required": true,
        "description": "Current page number (1-based).",
        "semanticType": "state.pagination.page"
      },
      "pageSize": {
        "type": "number",
        "required": true,
        "description": "Number of items displayed per page.",
        "semanticType": "state.pagination.pageSize"
      },
      "totalItems": {
        "type": "number",
        "required": false,
        "description": "Total number of items across all pages. Used to compute total page count.",
        "semanticType": "metric.pagination.totalItems"
      },
      "totalPages": {
        "type": "number",
        "required": false,
        "description": "Computed total number of pages (ceil(totalItems / pageSize)).",
        "semanticType": "metric.pagination.totalPages"
      },
      "product_id": {
        "type": "uuid",
        "required": true,
        "description": "Primary identifier for the product listing.",
        "semanticType": "product.id"
      },
      "sku": {
        "type": "string",
        "required": true,
        "description": "Merchandising SKU exposed to commerce systems.",
        "semanticType": "product.sku"
      },
      "inventory_status": {
        "type": "string",
        "required": true,
        "description": "Availability state synchronized with inventory service.",
        "enum": [
          "in_stock",
          "low_stock",
          "backorder",
          "discontinued"
        ],
        "semanticType": "product.inventory.status"
      },
      "release_channel": {
        "type": "string",
        "required": true,
        "description": "Channel describing how the product is released to customers.",
        "enum": [
          "alpha",
          "beta",
          "limited",
          "general_availability"
        ],
        "semanticType": "product.release.channel"
      },
      "requires_subscription": {
        "type": "boolean",
        "required": true,
        "description": "Indicates whether access to the product requires an active subscription.",
        "semanticType": "product.access.requires_subscription"
      },
      "support_level": {
        "type": "string",
        "required": false,
        "description": "SLA tier associated with the product.",
        "enum": [
          "standard",
          "premium",
          "enterprise"
        ]
      },
      "summary_blurb": {
        "type": "string",
        "required": false,
        "description": "Short merchandising description surfaced in marketing contexts."
      }
    }
  },
