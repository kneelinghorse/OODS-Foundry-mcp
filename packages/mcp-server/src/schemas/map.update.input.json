{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designlab.local/schemas/map.update.input.json",
  "title": "map.update input",
  "description": "Partially update an existing component-to-trait mapping.",
  "type": "object",
  "required": ["id", "updates"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Mapping ID to update (e.g., 'material-button')."
    },
    "updates": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Fields to update. Only provided fields are changed.",
      "properties": {
        "oodsTraits": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "description": "Replace OODS trait list."
        },
        "confidence": {
          "type": "string",
          "enum": ["auto", "manual"],
          "description": "Update confidence level."
        },
        "propMappings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["externalProp", "oodsProp"],
            "additionalProperties": false,
            "properties": {
              "externalProp": { "type": "string", "minLength": 1 },
              "oodsProp": { "type": "string", "minLength": 1 },
              "coercion": {
                "description": "Prop coercion. Accepts a structured CoercionDef, a raw string label (Stage1 v1.6.0 emits enum-map | type-cast | identity as pass-through hints), or null for identity.",
                "oneOf": [
                  { "type": "null" },
                  { "type": "string", "minLength": 1 },
                  {
                    "type": "object",
                    "required": ["type", "mapping"],
                    "additionalProperties": false,
                    "properties": {
                      "type": { "const": "enum" },
                      "mapping": { "type": "object", "additionalProperties": { "type": "string" } }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["type", "trueValue", "falseValue"],
                    "additionalProperties": false,
                    "properties": {
                      "type": { "const": "boolean_to_string" },
                      "trueValue": { "type": "string" },
                      "falseValue": { "type": "string" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["type", "pattern"],
                    "additionalProperties": false,
                    "properties": {
                      "type": { "const": "template" },
                      "pattern": { "type": "string" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["type"],
                    "additionalProperties": false,
                    "properties": {
                      "type": { "const": "identity" }
                    }
                  }
                ],
                "default": null
              }
            }
          },
          "description": "Replace property mappings."
        },
        "notes": {
          "type": "string",
          "description": "Update notes in metadata."
        },
        "projection_variants": {
          "type": "array",
          "description": "Replace Stage1 v1.5.0 cross-surface projection variants. Pass an empty array to clear; omit to leave unchanged.",
          "items": {
            "type": "object",
            "required": ["id", "surface"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "surface": { "type": "string", "minLength": 1 },
              "external_component": { "type": "string", "minLength": 1 },
              "capability_id": { "type": "string", "minLength": 1 },
              "selector": { "type": "string", "minLength": 1 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "evidence_chain": {
                "type": "array",
                "items": { "type": "object", "additionalProperties": true }
              },
              "metadata": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    }
  }
}
