{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "domain": { "type": "string" },
    "description": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "traits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "alias": { "type": ["string", "null"] },
          "parameters": { "type": ["object", "null"] }
        },
        "required": ["name", "alias", "parameters"],
        "additionalProperties": false
      }
    },
    "schema": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "description": { "type": "string" },
          "default": {},
          "defaultFromParameter": { "type": "string" },
          "validation": {
            "type": "object"
          }
        },
        "required": ["type", "required", "description"],
        "additionalProperties": true
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "semantic_type": { "type": "string" },
          "token_mapping": { "type": "string" },
          "ui_hints": {
            "type": "object",
            "additionalProperties": { "type": ["string", "boolean", "number"] }
          }
        },
        "required": ["semantic_type", "token_mapping"],
        "additionalProperties": false
      }
    },
    "viewExtensions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "component": { "type": "string" },
            "position": { "type": "string" },
            "priority": { "type": "number" },
            "props": { "type": "object" }
          },
          "required": ["component"],
          "additionalProperties": false
        }
      }
    },
    "tokens": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "filePath": { "type": "string" }
  },
  "required": ["name", "version", "domain", "description", "tags", "traits", "schema", "semantics", "viewExtensions", "tokens", "warnings", "filePath"],
  "additionalProperties": false
}
